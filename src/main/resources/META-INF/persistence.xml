<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.2"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
    <persistence-unit name="public_transport_company_pu">
        <class>GiorgiaFormicola.entities.MezzoDiTrasporto</class>
        <class>GiorgiaFormicola.entities.Autobus</class>
        <class>GiorgiaFormicola.entities.Tram</class>
        <class>GiorgiaFormicola.entities.OperativitàMezzo</class>
        <class>GiorgiaFormicola.entities.Manutenzione</class>
        <class>GiorgiaFormicola.entities.Servizio</class>
        <class>GiorgiaFormicola.entities.PuntiEmissione</class>
        <class>GiorgiaFormicola.entities.DistributoriAutomatici</class>
        <class>GiorgiaFormicola.entities.RivenditoriAutorizzati</class>
        <class>GiorgiaFormicola.entities.Emissione</class>
        <class>GiorgiaFormicola.entities.Biglietto</class>
        <class>GiorgiaFormicola.entities.Abbonamento</class>
        <class>GiorgiaFormicola.entities.Tessera</class>
        <class>GiorgiaFormicola.entities.Utente</class>
        <class>GiorgiaFormicola.entities.Tratta</class>
        <class>GiorgiaFormicola.entities.TrattaMezzo</class>
        <properties>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5432/public_transport_company"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>